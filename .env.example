# ==============================
# FRONT-END (Vite/browser)
# ==============================
# Use the Supabase project API URL + anon key here.
# IMPORTANT: do not put postgres:// credentials in VITE_* variables.
# NOTE: every VITE_* variable is PUBLIC (bundled into the browser). Only put
#       publishable/anon keys here — never private API keys or client secrets.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Official site URL used to build the OAuth redirect target.
# Leave blank in dev (the app falls back to window.location.origin).
# Set it in production to the official domain:
VITE_SITE_URL=https://finance.pedropaulocf.com.br

# Stripe publishable key (safe to expose).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ------------------------------------------------------------------
# GOOGLE OAUTH (Login com Google)
# ------------------------------------------------------------------
# The Google client_id / client_secret are NOT set here. With Supabase Auth
# they are configured in the Supabase Dashboard:
#   Authentication > Providers > Google
# And the redirect_uri registered in Google Cloud Console must be the Supabase
# callback URL (NOT this app's URL):
#   https://<your-project-ref>.supabase.co/auth/v1/callback
# See docs/google-oauth-setup.md for the full step-by-step.

# Optional compatibility aliases (same values as above)
# VITE_DATABASE_URL=https://your-project.supabase.co
# VITE_DATABASE_ANON_KEY=your-anon-key

# ==============================
# SERVER-ONLY (Node/back-end)
# ==============================
# Put your internal Postgres connection here (from Credenciais > URL de Conexão Interna):
# Example from your panel:
# DATABASE_URL=postgres://postgres:Wpp_9569%4026@n8n_postgres:5432/n8n?sslmode=disable
#
# Field mapping:
# - Usuário -> postgres (before : in URL auth)
# - Senha -> must be URL-encoded (@ becomes %40)
# - Nome do Banco de Dados -> /n8n
# - Host Interno -> n8n_postgres
# - Porta Interna -> 5432
